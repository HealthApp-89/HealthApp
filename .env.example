# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WHOOP OAuth (https://developer.whoop.com)
WHOOP_CLIENT_ID=your-whoop-client-id
WHOOP_CLIENT_SECRET=your-whoop-client-secret
WHOOP_REDIRECT_URI=http://localhost:3000/api/whoop/callback

# Anthropic (server-side only — replaces browser-exposed key from prototype)
ANTHROPIC_API_KEY=your-anthropic-key

# Apple Health ingest webhook — random shared secret the iOS Shortcut sends as a header
APPLE_HEALTH_INGEST_SECRET=generate-a-long-random-string

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
