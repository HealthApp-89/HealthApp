# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WHOOP OAuth (https://developer.whoop.com)
WHOOP_CLIENT_ID=your-whoop-client-id
WHOOP_CLIENT_SECRET=your-whoop-client-secret
WHOOP_REDIRECT_URI=http://localhost:3000/api/whoop/callback

# Withings OAuth (https://developer.withings.com)
WITHINGS_CLIENT_ID=your-withings-client-id
WITHINGS_CLIENT_SECRET=your-withings-client-secret
WITHINGS_REDIRECT_URI=http://localhost:3000/api/withings/callback

# Strava OAuth (https://www.strava.com/settings/api). Free accounts get 1 app.
# Register with the prod domain as the callback. The OAuth flow populates
# strava_tokens rows in Supabase — the app reads tokens from there, never
# from env. Only CLIENT_ID / CLIENT_SECRET / VERIFY_TOKEN / WEBHOOK_CALLBACK_URL
# are read by the app code. REDIRECT_URI / ACCESS_TOKEN / REFRESH_TOKEN are
# kept here for one-shot dev scripts (e.g. seeding tokens manually); the
# production code path does not read them.
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_REDIRECT_URI=https://your-prod-domain/api/strava/callback
STRAVA_ACCESS_TOKEN=your-strava-access-token
STRAVA_REFRESH_TOKEN=your-strava-refresh-token
# Random 32-char, used by the webhook subscription handshake
STRAVA_VERIFY_TOKEN=
# Public callback URL — must match the Authorization Callback Domain in your Strava app
STRAVA_WEBHOOK_CALLBACK_URL=

# Anthropic (server-side only — replaces browser-exposed key from prototype)
ANTHROPIC_API_KEY=your-anthropic-key

# USDA FoodData Central — free key at https://fdc.nal.usda.gov/api-guide.html
USDA_FDC_API_KEY=your-usda-fdc-key

# Apple Health / Strong / Yazio ingest is per-user. Tokens are generated from
# /profile (rotated on demand) and sent as `Authorization: Bearer <token>` to
# /api/ingest/health (Apple Health, Yazio→HealthKit) and /api/ingest/strong.
# No global secret needed.

# Vercel cron secret — random long string; Vercel sends it as Authorization: Bearer <this>
CRON_SECRET=generate-a-long-random-string

# 32+ char random string used to sign coach plan/block approval tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COACH_TOOL_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# IANA timezone used for all server-side "today" / "now" computations and
# the LLM coach prompt's NOW: anchor. Defaults to Asia/Dubai if unset.
# Example overrides for dev: America/Los_Angeles, Europe/Paris.
USER_TIMEZONE=Asia/Dubai

# Kill switch for in-app food logging's ownership of the daily_logs nutrition
# columns (calories_eaten, protein_g, carbs_g, fat_g, fiber_g). Default ON.
# Set to "false" to revert to Yazio-as-primary while testing meal logging:
# food_log_entries rows still write and /meal still renders them, but the
# daily_logs upsert is skipped and Yazio is allowed to overwrite the day.
FOOD_LOG_OWNS_DAILY_LOGS=true
